from flask import Flask
from flask_sqlalchemy import SQLAlchemy

app = Flask(__name__)

# ✅ USE SQLITE (SAME AS YOUR MAIN APP)
app.config['SQLALCHEMY_DATABASE_URI'] = 'sqlite:///hotel.db'
app.config['SQLALCHEMY_TRACK_MODIFICATIONS'] = False

db = SQLAlchemy(app)

class MenuItem(db.Model):
    id = db.Column(db.Integer, primary_key=True)

    name = db.Column(db.String(100))
    price = db.Column(db.Float)
    hotel = db.Column(db.String(100))

    image = db.Column(db.String(100))  # ✅ MUST EXIST


with app.app_context():
    db.create_all()

    # Insert data if empty
    if MenuItem.query.count() == 0:
        items = [
    MenuItem(name="Chicken Curry", price=150, hotel="lazar", image="chicken.jpeg"),
    MenuItem(name="Egg Curry", price=120, hotel="lazar", image="egg.jpeg"),
    MenuItem(name="Mutton Fry", price=200, hotel="lazar", image="mutton3.jpeg"),
]

        db.session.add_all(items)
        db.session.commit()

    print("✅ SQLite DB ready with data!")